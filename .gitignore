# Python
# ============================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
.venv/
ENV/
.eggs/
*.egg-info/

# ============================================
# IDE
# ============================================
.vscode/
.idea/
*.swp
*.swo

# ============================================
